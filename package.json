{
  "name": "icount-mcp",
  "version": "0.1.0",
  "description": "Multi-tenant MCP server for iCount (Israeli invoicing/accounting). Streamable HTTP on Vercel Edge.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "stdio": "tsx src/stdio.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vercel": "^39.0.0",
    "vitest": "^2.0.0"
  }
}
